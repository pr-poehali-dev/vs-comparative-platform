{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET me without session — 401",
      "method": "GET",
      "path": "/",
      "expectedStatus": 401
    },
    {
      "name": "Login wrong credentials — 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "login": "nobody@test.com", "password": "wrongpass"},
      "expectedStatus": 401
    },
    {
      "name": "Register missing fields — 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "name": "", "username": "", "email": "", "password": ""},
      "expectedStatus": 400
    }
  ]
}